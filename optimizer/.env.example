# ── App ──────────────────────────────────────────────────────────────────────
APP_VERSION=2.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=otmiz_new
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Backend NestJS ────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3001/api/v1
BACKEND_SECRET=optimizer-internal-secret

# ── Algoritmos ────────────────────────────────────────────────────────────────
GA_POPULATION_SIZE=100
GA_GENERATIONS=200
GA_MUTATION_RATE=0.1

SA_INITIAL_TEMP=1000.0
SA_COOLING_RATE=0.995

TS_TABU_SIZE=20
TS_MAX_ITERATIONS=500

ILP_TIMEOUT_SECONDS=120
HYBRID_TIME_BUDGET_SECONDS=300

# ── Custos padrão ────────────────────────────────────────────────────────────
DEFAULT_VEHICLE_FIXED_COST=800.0
DEFAULT_COST_PER_KM=2.0
DEFAULT_COST_PER_HOUR=50.0

# ── CCT ─────────────────────────────────────────────────────────────────────
CCT_MAX_SHIFT_MINUTES=480
CCT_MAX_DRIVING_MINUTES=270
CCT_MIN_BREAK_MINUTES=30
